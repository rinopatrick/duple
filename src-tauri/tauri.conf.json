{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/main/docs/.vitepress/theme/schema.json",
  "productName": "Duple",
  "version": "0.1.0",
  "identifier": "com.duple.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Duple",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "sql": {
      "preload": {
        "db": "sqlite:duple.db"
      }
    }
  }
}
