{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/main/docs/.vitepress/theme/schema.json",
  "productName": "Duple",
  "version": "0.1.0",
  "identifier": "com.duple.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Duple — Your Relationship Sidekick",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "visible": true,
        "decorations": true,
        "alwaysOnTop": false
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "tooltip": "Duple"
    },
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "sql": {
      "preload": {
        "db": "sqlite:duple.db"
      }
    },
    "notification": {
      "all": true
    }
  }
}
